# Path to the directory holding the Parquet datasets (required in production).
# Layout expected underneath:
#   $CME_FUTURES_DATA_DIR/futures_daily_badj/<SYM>/1d.parquet   (back-adjusted, daily)
#   $CME_FUTURES_DATA_DIR/futures/<SYM>/<tf>.parquet            (front-month, intraday)
CME_FUTURES_DATA_DIR=/absolute/path/to/data
